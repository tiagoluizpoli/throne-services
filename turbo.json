{
  "extends": ["//"],
  "tasks": {
    "dev": {
      "inputs": [".env"],
      "cache": false,
      "persistent": true
    },
    "dev:api": {
      "inputs": [".env"],
      "cache": false,
      "persistent": true
    },
    "dev:app": {
      "inputs": [".env"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "cache": false
    },
    "test:watch": {},
    "test:watch:verbose": {},
    "test:unit": {
      "cache": false
    },
    "test:unit:watch": {},
    "test:integration": {},
    "test:integration:watch": {},
    "typecheck": {
      "cache": false
    },
    "lint": {},
    "lint:fix": {},
    "clean": {
      "cache": false
    },
    "clean:build": {},
    "clean:node_modules": {},
    "prisma:generate": {
      "persistent": true,
      "cache": false
    },
    "db:migrate:dev": {},
    "db:seed": {
      "cache": false
    },
    "db:drizzle:sync": {
      "cache": false
    },
    "db:sync": {
      "persistent": true,
      "cache": false
    },
    "prepare:tf": {
      "cache": false
    }
  }
